{
  "name": "tui-nes",
  "version": "0.1.0",
  "description": "A terminal-based NES emulator written in TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tui-nes": "dist/index.js"
  },
  "scripts": {
    "dev": "tsup src/index.ts --watch --onSuccess 'node dist/index.js'",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "nes",
    "emulator",
    "terminal",
    "tui",
    "6502"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "ink": "^5.0.1",
    "node-hid": "^3.1.0",
    "react": "^18.3.1",
    "speaker": "^0.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-hid": "^1.3.4",
    "@types/react": "^18.3.12",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
